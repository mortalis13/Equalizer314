<?xml version="1.0" encoding="utf-8"?>
<!-- Persistent "Session detection" toggle card. Matches the Simple EQ
     card pattern from activity_main.xml — solid surface-container-high
     background, no stroke, MaterialSwitch on the right. The switch
     reflects the system Notification access state; tapping it routes
     the user to system Settings, which is the only place Android lets
     a third-party app flip BIND_NOTIFICATION_LISTENER_SERVICE on or
     off. The visual snap-back is handled in ChannelInputActivity. -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/enableDetectionCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/enableDetectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Session detection"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/enableDetectionBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lists every app currently playing audio"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingTop="4dp" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/enableDetectionSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
