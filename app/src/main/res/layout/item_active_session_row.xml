<?xml version="1.0" encoding="utf-8"?>
<!-- One row in the "Current session" panel — a single app currently
     broadcasting an OPEN_AUDIO_EFFECT_CONTROL_SESSION. Compact two-
     line layout: app icon + name on top, package + session id + bound
     preset on the bottom. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/sessionRowIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="12dp"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/sessionRowName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/sessionRowMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Animated "now playing" pulse — speaker cone with sound waves
         emanating. Indicates the row's app is outputting audio right
         now. Source distinction (BROADCAST vs DETECTED) lives in the
         meta TextView, so this is purely a "this is live" affordance. -->
    <ImageView
        android:id="@+id/sessionRowPulse"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="8dp"
        android:contentDescription="@null"
        android:src="@drawable/anim_speaker_pulse" />
</LinearLayout>
