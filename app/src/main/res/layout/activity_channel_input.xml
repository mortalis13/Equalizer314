<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/channelInputBackButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="?attr/colorOnSurface" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Channel Input"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:paddingStart="8dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="32dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Description card — temporarily hidden. The plan is to
                 surface this copy as a tooltip on the screen header
                 down the road, so the markup stays for reference.
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="Bind a saved EQ preset to a specific app. When that app starts playing audio and broadcasts a session open (Spotify, Poweramp, AIMP, and many others do), its preset is applied automatically to its audio session — without affecting other apps."
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </com.google.android.material.card.MaterialCardView>
            -->

            <!-- CTA shown until the user grants Notification access — see
                 PlaybackListenerService for why we need it (privilege gate
                 only; no notifications are read). -->
            <include layout="@layout/card_enable_detection" />

            <!-- "Skip system sounds" toggle — default ON. Bypasses the
                 global DP on notification/ringtone/alarm/call streams
                 to avoid the 127-band pre-EQ + limiter distorting them. -->
            <include layout="@layout/card_bypass_system_sounds" />

            <!-- Routing mode selector — placed directly under the
                 Session detection card so the two top-level toggles
                 read as one settings group. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Routing mode"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingStart="4dp"
                android:paddingBottom="6dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/routingModeChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:chipSpacingHorizontal="8dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/routingModeGlobal"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System-wide"
                    android:textSize="14sp"
                    app:chipMinHeight="44dp"
                    app:chipStartPadding="14dp"
                    app:chipEndPadding="14dp"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/routingModePerApp"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Session-based"
                    android:textSize="14sp"
                    app:chipMinHeight="44dp"
                    app:chipStartPadding="14dp"
                    app:chipEndPadding="14dp"
                    app:checkedIconVisible="false" />
            </com.google.android.material.chip.ChipGroup>

            <!-- "Now playing": every app currently producing audio. Includes
                 apps that broadcast OPEN_AUDIO_EFFECT_CONTROL_SESSION
                 (Spotify, Poweramp, AIMP — "Bound" badge) and apps detected
                 via the dump-parse path (YouTube, Netflix — "Detected" badge).
                 Visible in both routing modes; only the DP attach is gated
                 by Session-based mode. Updated live via
                 SessionEffectManager.ACTION_SESSIONS_CHANGED. -->
            <LinearLayout
                android:id="@+id/currentSessionSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Now playing"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:paddingStart="4dp"
                    android:paddingBottom="6dp" />

                <!-- No outer wrapper card — each row is its own outlined
                     card, matching the Apps list below. -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/currentSessionList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/currentSessionEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="No sessions detected"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Apps section — collapsible header + body, mirrors the
                 Devices section pattern from activity_audio_output. -->
            <LinearLayout
                android:id="@+id/appsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/ripple_rounded_header"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Apps"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/appsChevron"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▸"
                    android:textSize="22sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Collapsible body: list + empty state. -->
            <LinearLayout
                android:id="@+id/appsBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- Filtered (default) vs Show All chip selector. Filtered
                 = the media-relevant heuristic (MEDIA_BUTTON receiver /
                 MediaBrowserService / audio MIME / seen / bound). Show
                 All = every installed app, alphabetical. Same chip
                 styling as routingModeChips above. -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/appsFilterChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                app:chipSpacingHorizontal="8dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/appsFilterFiltered"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filtered"
                    android:textSize="14sp"
                    app:chipMinHeight="44dp"
                    app:chipStartPadding="14dp"
                    app:chipEndPadding="14dp"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/appsFilterShowAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show All"
                    android:textSize="14sp"
                    app:chipMinHeight="44dp"
                    app:chipStartPadding="14dp"
                    app:chipEndPadding="14dp"
                    app:checkedIconVisible="false" />
            </com.google.android.material.chip.ChipGroup>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/appsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <!-- Shows "Loading apps…" during the initial coroutine-
                 backed enumeration, then either hides (rows arrived)
                 or switches to a "No apps" message. Default visible
                 so the user sees something on first frame instead of
                 a blank list. -->
            <TextView
                android:id="@+id/appsEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading apps…"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:padding="32dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
