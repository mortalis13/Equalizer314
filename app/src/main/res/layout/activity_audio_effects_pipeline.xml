<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/audioPipelineBackButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="?attr/colorOnSurface" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Audio Effects Pipeline"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:paddingStart="8dp" />

        <!-- Info icon on the right side of the title. Tap toggles the
             how-to card below. Tint starts dim (the card is hidden by
             default) and brightens when the card is shown. Borderless
             ripple keeps the round visual matching the back button on
             the left. -->
        <ImageButton
            android:id="@+id/audioPipelineInfoButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_info_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Pipeline info"
            app:tint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <!-- Info / how-to card. Hidden by default; toggled by the info
         button in the top bar. Smooth height-based show/hide is
         applied in AudioEffectsPipelineActivity (same animation
         pattern as the Apps / Devices collapsible sections). -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/audioPipelineInfoCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:text="Drag the handle on the left of each effects card to re-order the order of the processing effects chain. The audio stream begins from Channel Input and ends at the Audio Output. DynamicsProcessing is the main EQ, MBC, Limiting that is exposed in the app, the other audio effects that can attach to the channel input can be clicked on and edited right here in a new screen."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/audioPipelineRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="32dp"
        android:scrollbars="none" />

</LinearLayout>
