<?xml version="1.0" encoding="utf-8"?>
<!-- "Skip system sounds" toggle card on the Channel Input screen.
     Same visual pattern as card_enable_detection.xml. Default ON in
     prefs — protects against the 127-band pre-EQ + limiter chain
     distorting notification / ringtone / alarm / call audio. Users
     who want every stream EQ'd can flip it off. -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bypassSystemSoundsCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/bypassSystemSoundsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Skip system sounds"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/bypassSystemSoundsBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Turns processing off for system sounds"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingTop="4dp" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/bypassSystemSoundsSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
